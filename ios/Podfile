require_relative '../node_modules/react-native/scripts/react_native_pods'
require_relative '../node_modules/@react-native-community/cli-platform-ios/native_modules'

platform :ios, '16.0'
prepare_react_native_project!

target 'MeoPhim' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # Enable hermes only if needed
    :hermes_enabled => true
  )

  target 'MeoPhimTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # Default React Native post install
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    # Configure all targets
    installer.pods_project.targets.each do |target|
      # Fix lỗi leveldb-library
      if target.name == 'leveldb-library'
        target.build_configurations.each do |config|
          config.build_settings['SKIP_INSTALL'] = 'YES'
        end
      end

      # Fix lỗi Resource Bundle không tìm thấy file
      if target.respond_to?(:resource_bundle_targets)
        target.resource_bundle_targets.each do |res_target|
          res_target.build_configurations.each do |config|
            config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
          end
        end
      end

      if target.name == 'react-native-tcp-socket'
        target.build_configurations.each do |config|
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)', 'GCDAsyncSocket=MeoGCDAsyncSocket']
        end
      end

      target.build_configurations.each do |config|
        # Ép tất cả target dùng SDK iPhone thật và kiến trúc arm64
        config.build_settings['SDKROOT'] = 'iphoneos'
        config.build_settings['ARCHS'] = 'arm64'
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'

        # Sửa lỗi Linking và Frameworks hệ thống
        ldflags = ['$(inherited)', '-lc++', '-lsqlite3', '-lz', '-framework CoreAudio', '-framework CoreAudioTypes', '-framework AudioToolbox', '-framework AVFoundation', '-Wl,-flat_namespace,-undefined,suppress']
        config.build_settings['OTHER_LDFLAGS'] = ldflags.join(' ')
        
        # Thêm LIBRARY_SEARCH_PATHS để tìm đúng Swift runtime
        lib_paths = ['$(inherited)', '"$(SDKROOT)/usr/lib/swift"', '"$(TOOLCHAIN_DIR)/usr/lib/swift/$(PLATFORM_NAME)"']
        config.build_settings['LIBRARY_SEARCH_PATHS'] = lib_paths.join(' ')
        
        # Cấu hình Build cho TrollStore (No stripping)
        config.build_settings['DEAD_CODE_STRIPPING'] = 'NO'
        config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'NO'

        # CHỈ BẬT ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES cho Target chính
        if target.name == 'MeoPhim'
          config.build_settings['ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES'] = 'YES'
        else
          config.build_settings['ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES'] = 'NO'
        end
      end
    end
  end
end
