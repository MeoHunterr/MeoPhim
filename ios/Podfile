require_relative '../node_modules/react-native/scripts/react_native_pods'
require_relative '../node_modules/@react-native-community/cli-platform-ios/native_modules'

platform :ios, '16.0'
prepare_react_native_project!

target 'MeoPhim' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # Enable hermes only if needed
    :hermes_enabled => true
  )

  target 'MeoPhimTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # Default React Native post install
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    # 1. Ép các thư viện Pods về iOS 16 và cấu hình cơ bản
    installer.pods_project.targets.each do |target|
      # Fix lỗi leveldb-library
      if target.name == 'leveldb-library'
        target.build_configurations.each do |config|
          config.build_settings['SKIP_INSTALL'] = 'YES'
        end
      end

      # Fix lỗi Resource Bundle không tìm thấy file
      if target.respond_to?(:resource_bundle_targets)
        target.resource_bundle_targets.each do |res_target|
          res_target.build_configurations.each do |config|
            config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
          end
        end
      end

      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
        config.build_settings['ONLY_ACTIVE_ARCH'] = 'NO'
        config.build_settings['SDKROOT'] = 'iphoneos'
        config.build_settings['ARCHS'] = 'arm64'
        config.build_settings['ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES'] = 'NO'
      end
    end

    # 2. HACK TRỰC TIẾP VÀO TARGET CHÍNH (MeoPhim) CỦA DỰ ÁN
    installer.aggregate_targets.each do |aggregate_target|
      aggregate_target.user_project.targets.each do |target|
        if target.name == 'MeoPhim'
          target.build_configurations.each do |config|
            # Bắt buộc thêm các cờ để Link C++ và Objective-C
            # Đảm bảo OTHER_LDFLAGS là mảng để tránh lỗi chuỗi
            ldflags = config.build_settings['OTHER_LDFLAGS']
            if ldflags.is_a?(String)
              ldflags = [ldflags]
            elsif ldflags.nil?
              ldflags = ['$(inherited)']
            end

            ldflags << '-ObjC'
            ldflags << '-lc++'
            ldflags << '-lsqlite3'
            ldflags << '-lz'
            
            # Xử lý triệt để lỗi CoreAudio
            ldflags << '-framework' << 'CoreAudio'
            ldflags << '-framework' << 'AudioToolbox'
            ldflags << '-framework' << 'AVFoundation'
            ldflags << '-framework' << 'Network'
            
            config.build_settings['OTHER_LDFLAGS'] = ldflags.uniq
            
            # Bắt buộc nhúng thư viện Swift
            config.build_settings['ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES'] = 'YES'
            
            lib_paths = config.build_settings['LIBRARY_SEARCH_PATHS']
            if lib_paths.is_a?(String)
              lib_paths = [lib_paths]
            elsif lib_paths.nil?
              lib_paths = ['$(inherited)']
            end
            lib_paths << '"$(TOOLCHAIN_DIR)/usr/lib/swift/$(PLATFORM_NAME)"'
            lib_paths << '"$(SDKROOT)/usr/lib/swift"'
            config.build_settings['LIBRARY_SEARCH_PATHS'] = lib_paths.uniq
            
            # Chống việc Xcode tự động xóa code
            config.build_settings['DEAD_CODE_STRIPPING'] = 'NO'
            config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'NO'
            config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
            config.build_settings['SDKROOT'] = 'iphoneos'
            config.build_settings['ARCHS'] = 'arm64'
          end
        end
      end
      aggregate_target.user_project.save
    end
  end
end
