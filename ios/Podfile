require_relative '../node_modules/react-native/scripts/react_native_pods'
require_relative '../node_modules/@react-native-community/cli-platform-ios/native_modules'

platform :ios, '16.0'
project 'MeoPhim.xcodeproj'

prepare_react_native_project!

target 'MeoPhim' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # Enable hermes only if needed
    :hermes_enabled => true
  )

  target 'MeoPhimTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # Default React Native post install
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    # 1. Ép tất cả các Pods về iOS 16.0
    installer.pods_project.targets.each do |target|
      # Fix lỗi leveldb-library
      if target.name == 'leveldb-library'
        target.build_configurations.each do |config|
          config.build_settings['SKIP_INSTALL'] = 'YES'
        end
      end

      # Fix lỗi Resource Bundle
      if target.respond_to?(:resource_bundle_targets)
        target.resource_bundle_targets.each do |res_target|
          res_target.build_configurations.each do |config|
            config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
          end
        end
      end

      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
        config.build_settings['ONLY_ACTIVE_ARCH'] = 'NO'
      end
    end

    # 2. ÉP TARGET CHÍNH (MeoPhim) LINK VỚI SWIFT RUNTIME
    installer.aggregate_targets.each do |aggregate_target|
      aggregate_target.user_project.targets.each do |target|
        if target.name == 'MeoPhim'
          target.build_configurations.each do |config|
            # Bật nhúng Swift Standard Libraries
            config.build_settings['ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES'] = 'YES'
            
            # Ép Linker tìm thư viện Swift
            config.build_settings['LIBRARY_SEARCH_PATHS'] ||= ['$(inherited)']
            config.build_settings['LIBRARY_SEARCH_PATHS'] << '"$(TOOLCHAIN_DIR)/usr/lib/swift/$(PLATFORM_NAME)"'
            config.build_settings['LIBRARY_SEARCH_PATHS'] << '"$(TOOLCHAIN_DIR)/usr/lib/swift-5.0/$(PLATFORM_NAME)"'
            config.build_settings['LIBRARY_SEARCH_PATHS'] << '"$(SDKROOT)/usr/lib/swift"'
            
            # Các cờ Linking cơ bản cho Torrent/Video
            config.build_settings['OTHER_LDFLAGS'] ||= ['$(inherited)']
            config.build_settings['OTHER_LDFLAGS'] << '-ObjC'
            config.build_settings['OTHER_LDFLAGS'] << '-lc++'
            
            # Link frameworks hệ thống cần thiết
            config.build_settings['OTHER_LDFLAGS'] << '-framework' << 'CoreAudio'
            config.build_settings['OTHER_LDFLAGS'] << '-framework' << 'AudioToolbox'
            config.build_settings['OTHER_LDFLAGS'] << '-framework' << 'AVFoundation'
            config.build_settings['OTHER_LDFLAGS'] << '-framework' << 'Network'
            
            # Các thiết lập quan trọng cho TrollStore
            config.build_settings['DEAD_CODE_STRIPPING'] = 'NO'
            config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'NO'
            config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
            config.build_settings['SDKROOT'] = 'iphoneos'
            config.build_settings['ARCHS'] = 'arm64'
          end
        end
      end
      aggregate_target.user_project.save
    end
  end
end
